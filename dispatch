#!/bin/sh
# Dispatch wrapper: prefer a packaged venv python if present, else fall back to system python3.
# Typical charm layout places a venv at: ./venv/bin/python3 or ./parts/charm/install/venv/bin/python3
for py in ./parts/*/install/venv/bin/python3 ./venv/bin/python3 /usr/bin/python3; do
  if [ -x "$py" ]; then
    exec "$py" ./src/charm.py "$@"
  fi
done

echo "ERROR: no suitable python3 interpreter found" >&2
exit 1
